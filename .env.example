# ============================================================
# Amartha eTicket — Environment Variables (copy ke .env)
# ============================================================

# --- API (Laravel) ---
APP_NAME="Amartha eTicket"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amartha_eticket
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# JWT
JWT_SECRET=
JWT_ALGO=HS256
JWT_ADMIN_TTL=480        # 8 jam (menit)
JWT_SUPERVISOR_TTL=480
JWT_SCANNER_TTL=1440     # 24 jam
JWT_KASIR_TTL=480
JWT_CUSTOMER_TTL=10080   # 7 hari

# Cloudinary — konfigurasi dikelola via Settings > General > Cloudinary di admin portal

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Email (Resend)
# Email — konfigurasi dikelola via Settings > General > Email di admin portal

# WhatsApp (Fonnte)
FONNTE_TOKEN=

# Seat Hold TTL (detik)
SEAT_HOLD_TTL=600

# Queue
QUEUE_CONNECTION=redis

# --- Storefront (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Admin Portal (Next.js) ---
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000/v1
